---
import GoogleTag from "../components/GoogleTag.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import SiteScripts from "../components/SiteScripts.astro";
import WineCard from "../components/WineCard.astro";
import ExperienceCard from "../components/ExperienceCard.astro";
import ReservationForm from "../components/ReservationForm.astro";
import {
  blogPosts,
  events,
  experiences,
  galleryItems,
  pressPublications,
  serviceCards,
  wines,
} from "../data/site";
import "../styles/global.css";

const baseUrl = import.meta.env.BASE_URL;
const featuredBlogPosts = blogPosts.slice(0, 3);
const featuredPress = pressPublications;
const homeGallery = galleryItems;

const pageLinks = [
  {
    title: "Sobre nosotros",
    text: "Historia, misión, visión y valores de WineNotFound.",
    href: `${baseUrl}sobre-nosotros/`,
  },
  {
    title: "Reservar",
    text: "Catas y comidas con formulario específico de reserva.",
    href: `${baseUrl}reservar/`,
  },
  {
    title: "Tienda",
    text: "Packs, referencias disponibles y suscripción privada.",
    href: `${baseUrl}tienda/`,
  },
  {
    title: "Blog",
    text: "Artículos sobre vino, bodega, restaurante y club privado.",
    href: `${baseUrl}blog/`,
  },
  {
    title: "Preguntas frecuentes",
    text: "Dudas habituales sobre envíos, catas, reservas, restaurante y suscripción.",
    href: `${baseUrl}faq/`,
  },
] as const;
---

<!doctype html>
<html lang="es">
  <head>
    <GoogleTag />
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="WineNotFound, bodega de partidas pequeñas, restaurante, catas privadas, suscripción y vinos con carácter propio."
    />
    <meta name="theme-color" content="#2b1018" />
    <link rel="icon" href={`${baseUrl}favicon.svg`} type="image/svg+xml" />
    <title>WineNotFound | Bodega, restaurante y catas privadas</title>
  </head>
  <body>
    <SiteHeader />

    <main>
      <section class="hero" id="inicio" aria-labelledby="hero-title">
        <div class="hero-media" aria-hidden="true">
          <video autoplay muted loop playsinline poster={`${baseUrl}images/hero-cellar.jpg`}>
            <source src={`${baseUrl}videos/bodega.webm`} type="video/webm" />
          </video>
        </div>
        <div class="hero-overlay" aria-hidden="true"></div>

        <div class="hero-content">
          <p class="eyebrow">Partidas pequeñas · Restaurante · Suscripción privada</p>
          <h1 id="hero-title">WineNotFound</h1>
          <p class="hero-copy">
            Elaboramos vinos de producción limitada y organizamos experiencias en bodega:
            catas, visitas técnicas, comidas, paseos por viñedos y una suscripción para seguir cada añada desde dentro.
          </p>
          <div class="hero-actions" aria-label="Acciones principales">
            <a class="button button-primary" href={`${baseUrl}reservar/`}>Reservar experiencia</a>
            <a class="button button-ghost" href={`${baseUrl}tienda/#suscripcion`}>Ver suscripción</a>
          </div>
        </div>

        <div class="hero-notes" aria-label="Datos de la bodega">
          <span><strong>2.700</strong> botellas por añada</span>
          <span><strong>5</strong> experiencias reservables</span>
          <span><strong>1</strong> vídeo de presentación</span>
        </div>
      </section>

      <section class="intro-band" aria-label="Resumen WineNotFound">
        <p>
          Una bodega pequeña con alma digital: vinos honestos, restaurante de temporada, experiencias cercanas
          y una tienda con suscripción para clientes que quieren seguir la historia completa.
        </p>
      </section>

      <section class="section hub-section" aria-labelledby="hub-title">
        <div class="section-heading">
          <p class="eyebrow">Explora el sitio</p>
          <h2 id="hub-title">Todo lo importante, bien separado</h2>
          <p>
            La home resume la empresa y enseña su actividad. Para ampliar información, cada bloque principal
            tiene su propia página.
          </p>
        </div>

        <div class="link-grid link-grid-wide">
          {pageLinks.map((item) => (
            <a class="link-card" href={item.href}>
              <span>Ver página</span>
              <h3>{item.title}</h3>
              <p>{item.text}</p>
            </a>
          ))}
        </div>
      </section>

      <section class="section products-section" id="productos" aria-labelledby="products-title">
        <div class="section-heading">
          <p class="eyebrow">Servicios y productos</p>
          <h2 id="products-title">Vinos, catas, restaurante y club privado</h2>
          <p>
            WineNotFound combina producto, experiencia y comunidad. Cada línea tiene una función concreta:
            comprar vino, aprender, comer en bodega o formar parte del club.
          </p>
        </div>

        <div class="services-grid services-grid-rich">
          {serviceCards.map((card) => (
            <article class="service-card">
              <span>{card.tag}</span>
              <h3>{card.title}</h3>
              <p>{card.text}</p>
              <ul class="compact-list">
                {card.benefits.map((benefit) => <li>{benefit}</li>)}
              </ul>
              <a class="text-link" href={`${baseUrl}${card.href}`}>Más info</a>
            </article>
          ))}
        </div>

      </section>

      <section class="section collection" id="vinos" aria-labelledby="collection-title">
        <div class="section-heading">
          <p class="eyebrow">Colección actual</p>
          <h2 id="collection-title">Añadas difíciles de encontrar</h2>
          <p>
            Siete referencias de producción limitada para mesas largas, conversaciones lentas y
            noches que no necesitan explicación.
          </p>
        </div>

        <div class="filter-bar" aria-label="Filtrar vinos">
          <button class="filter-button is-active" type="button" data-filter="all">Todos</button>
          <button class="filter-button" type="button" data-filter="red">Tintos</button>
          <button class="filter-button" type="button" data-filter="white">Blancos</button>
          <button class="filter-button" type="button" data-filter="special">Especiales</button>
        </div>

        <div class="wine-grid">
          {wines.map((wine) => <WineCard {...wine} />)}
        </div>
      </section>

      <section class="section cellar-section" id="bodega" aria-labelledby="cellar-title">
        <div class="cellar-copy">
          <p class="eyebrow">La bodega</p>
          <h2 id="cellar-title">Tradición sin modo avión</h2>
          <p>
            Trabajamos con depósitos pequeños, levaduras autóctonas y una crianza que escucha antes
            de decidir. La tecnología entra solo donde ayuda: control térmico, trazabilidad y una
            obsesión tranquila por el detalle.
          </p>
          <div class="cellar-list">
            <span>Vendimia nocturna</span>
            <span>Barricas francesas usadas</span>
            <span>Etiquetado manual</span>
          </div>
        </div>
        <figure class="cellar-image">
          <img src={`${baseUrl}images/still-life.jpg`} alt="Botella de vino tinto con copa y uvas" loading="lazy" />
          <figcaption>Edición de cata privada: botellas numeradas y servicio a temperatura exacta.</figcaption>
        </figure>
      </section>

      <section class="section experiences" id="experiencias" aria-labelledby="experience-title">
        <div class="section-heading">
          <p class="eyebrow">Experiencias</p>
          <h2 id="experience-title">Catas, visitas, comidas y viñedo</h2>
          <p>
            Cada experiencia explica qué se hace, cuánto dura, para quién está pensada y qué incluye.
          </p>
        </div>

        <div class="experience-grid">
          {experiences.map((experience) => <ExperienceCard {...experience} />)}
        </div>
      </section>

      <section
        class="club-band"
        aria-labelledby="club-title"
        style={`--club-image: url("${baseUrl}images/gallery-subscription.png")`}
      >
        <div>
          <p class="eyebrow">Club privado</p>
          <h2 id="club-title">The Missing Bottle List</h2>
        </div>
        <p>
          Acceso preferente a microvinificaciones, preventa de añadas, cajas seleccionadas,
          prioridad para reservar restaurante y descuentos en catas.
        </p>
        <a class="button button-primary" href={`${baseUrl}tienda/#suscripcion`}>Ver suscripción</a>
      </section>

      <section class="section gallery-section" id="galeria" aria-labelledby="gallery-title">
        <div class="section-heading">
          <p class="eyebrow">Galería</p>
          <h2 id="gallery-title">Fotos y vídeos de la bodega</h2>
          <p>
            Galería con imágenes, fotografías del sitio y vídeos locales que muestran bodega,
            restaurante, vendimia, suscripción y eventos.
          </p>
        </div>
        <div class="gallery-grid gallery-grid-expanded">
          {homeGallery.map((item) => (
            <figure class={`gallery-item ${item.span === "large" ? "gallery-large" : ""}`}>
              {item.type === "video" ? (
                <video autoplay muted loop playsinline poster={`${baseUrl}${item.poster}`}>
                  <source src={`${baseUrl}${item.src}`} type={item.mime} />
                </video>
              ) : (
                <img src={`${baseUrl}${item.src}`} alt={item.title} loading="lazy" />
              )}
              <figcaption>
                <strong>{item.title}</strong>
                <span>{item.text}</span>
              </figcaption>
            </figure>
          ))}
        </div>
      </section>

      <section class="section updates-section" id="actualidad" aria-labelledby="updates-title">
        <div class="section-heading">
          <p class="eyebrow">Blog, prensa y eventos</p>
          <h2 id="updates-title">Actualidad de la bodega</h2>
        </div>
        <div class="updates-grid updates-grid-rich">
          <div class="blog-list">
            {featuredBlogPosts.map((post) => (
              <article class="blog-card">
                <span>{post.category} · {post.date}</span>
                <h3>{post.title}</h3>
                <p>{post.text}</p>
                <a class="text-link" href={`${baseUrl}blog/`}>Leer en el blog</a>
              </article>
            ))}
          </div>
          <div class="press-list">
            <h3>Prensa</h3>
            <ul>
              {featuredPress.map((note) => (
                <li>
                  <strong>{note.source}</strong>
                  <span>{note.title}</span>
                </li>
              ))}
            </ul>
          </div>
          <div class="event-list">
            <h3>Calendario de eventos</h3>
            {events.map((event) => (
              <article>
                <span>{event.day}</span>
                <div>
                  <strong>{event.title}</strong>
                  <p>{event.meta}</p>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="section contact-section" id="contacto" aria-labelledby="contact-title">
        <div class="contact-copy">
          <p class="eyebrow">Contacto</p>
          <h2 id="contact-title">Hablemos de tu consulta</h2>
          <p>
            Este formulario es solo para preguntas, sugerencias o contacto general. Para reservar
            catas o comidas usa la página de reserva; para comprar o suscribirte, usa la tienda.
          </p>
          <address class="contact-card">
            <strong>WineNotFound S.L.</strong>
            <span>Ctra. Nacional 232, 26330 Briones, La Rioja</span>
            <a href="mailto:winenotfound@gmail.com">winenotfound@gmail.com</a>
            <a href="tel:+34910404404">+34 910 404 404</a>
          </address>
          <div class="social-links" aria-label="Redes sociales">
            <a href="https://www.instagram.com/wine.not.found" rel="noreferrer">Instagram</a>
            <a href="https://www.facebook.com/WineNotFound" rel="noreferrer">Facebook</a>
            <a href="https://www.linkedin.com/" rel="noreferrer">LinkedIn</a>
          </div>
        </div>

        <ReservationForm />
      </section>
    </main>

    <SiteFooter />
    <SiteScripts />
  </body>
</html>
