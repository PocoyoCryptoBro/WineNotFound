---
import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteScripts from "../components/SiteScripts.astro";
import { shopItems, subscriptionPlans, wines } from "../data/site";
import "../styles/global.css";

const baseUrl = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Tienda online ficticia de WineNotFound con packs, vinos y suscripción privada The Missing Bottle List."
    />
    <meta name="theme-color" content="#2b1018" />
    <link rel="icon" href={`${baseUrl}favicon.svg`} type="image/svg+xml" />
    <title>Tienda | WineNotFound</title>
  </head>
  <body>
    <SiteHeader />

    <main class="shop-main">
      <button class="cart-pill" type="button" data-cart-toggle aria-expanded="false" aria-controls="cart-dropdown">
        Carrito
        <span data-cart-count>0 productos</span>
      </button>

      <aside class="cart-dropdown" id="cart-dropdown" aria-label="Resumen del carrito" data-cart-dropdown hidden>
        <div class="cart-panel-heading">
          <h3>Carrito</h3>
          <button class="cart-close" type="button" data-cart-close aria-label="Cerrar carrito">Cerrar</button>
        </div>
        <p class="cart-empty" data-cart-empty>El carrito está vacío.</p>
        <ul class="cart-list" data-cart-list></ul>
        <div class="cart-total">
          <span>Total</span>
          <strong data-cart-total>0,00 €</strong>
        </div>
        <div class="cart-actions">
          <button class="button button-outline" type="button" data-cart-clear disabled>Vaciar</button>
          <button class="button button-primary" type="button" data-cart-checkout disabled>Finalizar pedido</button>
        </div>
      </aside>
      <section class="page-hero" aria-labelledby="shop-page-title">
        <p class="eyebrow">Tienda online</p>
        <h1 id="shop-page-title">Comprar en WineNotFound</h1>
      </section>

      <section class="section shop-section" aria-labelledby="packs-title">
        <div class="section-heading">
          <p class="eyebrow">Packs destacados</p>
          <h2 id="packs-title">Packs, regalos y experiencias</h2>
        </div>

        <div class="shop-grid shop-grid-rich">
          {shopItems.map((item) => (
            <article class="product-tile">
              <img class="product-image" src={`${baseUrl}${item.image}`} alt={item.imageAlt} loading="lazy" />
              <p>{item.price}</p>
              <h3>{item.title}</h3>
              <span>{item.text}</span>
              <ul class="compact-list">
                {item.benefits.map((benefit) => <li>{benefit}</li>)}
              </ul>
              <div class="product-actions">
                <button
                  class="button button-primary"
                  type="button"
                  data-cart-add
                  data-id={item.id}
                  data-name={item.title}
                  data-price={item.priceValue}
                  data-cycle={item.cycle}
                >
                  Añadir al carrito
                </button>
                <button
                  class="button button-outline"
                  type="button"
                  data-cart-buy
                  data-id={item.id}
                  data-name={item.title}
                  data-price={item.priceValue}
                  data-cycle={item.cycle}
                >
                  Pagar ya
                </button>
              </div>
            </article>
          ))}
        </div>
      </section>

      <section class="section collection" aria-labelledby="catalog-title">
        <div class="section-heading">
          <p class="eyebrow">Referencias</p>
          <h2 id="catalog-title">Vinos disponibles</h2>
          <p>Compra botellas sueltas de la colección actual, incluidos los nuevos vinos añadidos al catálogo.</p>
        </div>

        <div class="shop-grid shop-grid-rich">
          {wines.map((wine) => (
            <article class="product-tile wine-product-tile" data-type={wine.type}>
              <img class="product-image" src={`${baseUrl}${wine.image}`} alt={wine.imageAlt} loading="lazy" />
              <p>{wine.price}</p>
              <h3>{wine.title}</h3>
              <span>{wine.description}</span>
              <ul class="compact-list">
                <li>{wine.kind} · {wine.vintage}</li>
                <li>Crianza: {wine.ageing}</li>
                <li>{wine.bottles} botellas</li>
              </ul>
              <div class="product-actions">
                <button
                  class="button button-primary"
                  type="button"
                  data-cart-add
                  data-id={wine.id}
                  data-name={wine.title}
                  data-price={wine.priceValue}
                  data-cycle={wine.cycle}
                >
                  Añadir al carrito
                </button>
                <button
                  class="button button-outline"
                  type="button"
                  data-cart-buy
                  data-id={wine.id}
                  data-name={wine.title}
                  data-price={wine.priceValue}
                  data-cycle={wine.cycle}
                >
                  Pagar ya
                </button>
              </div>
            </article>
          ))}
        </div>
      </section>

      <section class="section subscription-section" id="suscripcion" aria-labelledby="subscription-title">
        <div class="section-heading">
          <p class="eyebrow">Suscripción</p>
          <h2 id="subscription-title">The Missing Bottle List</h2>
        </div>

        <div class="subscription-layout">
          <figure class="subscription-media">
            <img src={`${baseUrl}images/gallery-subscription.png`} alt="Caja de suscripción WineNotFound" loading="lazy" />
            <figcaption>Caja de temporada con notas de cata, acceso anticipado y cupo prioritario.</figcaption>
          </figure>
          <div class="subscription-plans">
            {subscriptionPlans.map((plan) => (
              <article class="product-tile subscription-plan">
                <img class="product-image" src={`${baseUrl}${plan.image}`} alt={plan.imageAlt} loading="lazy" />
                <p>{plan.price}</p>
                <h3>{plan.title}</h3>
                <span>{plan.text}</span>
                <ul class="compact-list">
                  {plan.benefits.map((benefit) => <li>{benefit}</li>)}
                </ul>
                <div class="product-actions">
                  <button
                    class="button button-primary"
                    type="button"
                    data-cart-add
                    data-id={plan.id}
                    data-name={plan.title}
                    data-price={plan.priceValue}
                    data-cycle={plan.cycle}
                  >
                    Añadir al carrito
                  </button>
                  <button
                    class="button button-outline"
                    type="button"
                    data-cart-buy
                    data-id={plan.id}
                    data-name={plan.title}
                    data-price={plan.priceValue}
                    data-cycle={plan.cycle}
                  >
                    Pagar ya
                  </button>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="section detail-section" aria-labelledby="conditions-title">
        <div class="section-heading">
          <p class="eyebrow">Pedido</p>
          <h2 id="conditions-title">Entrega y regalos</h2>
        </div>
        <div class="detail-grid">
          <article class="content-panel">
            <h3>Disponibilidad</h3>
            <p>Las botellas son limitadas y se confirman siempre antes de cerrar el pedido.</p>
          </article>
          <article class="content-panel">
            <h3>Envíos</h3>
            <p>Envíos nacionales ficticios en 48-72 horas laborables tras confirmación.</p>
          </article>
          <article class="content-panel">
            <h3>Regalos</h3>
            <p>Posibilidad de preparar bono de cata, pack personalizado o alta de suscripción con mensaje.</p>
          </article>
        </div>
      </section>
    </main>

    <SiteFooter />
    <SiteScripts />
  </body>
</html>
