---
import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteScripts from "../components/SiteScripts.astro";
import WineCard from "../components/WineCard.astro";
import { purchaseSteps, shopItems, wines } from "../data/site";
import "../styles/global.css";

const baseUrl = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Tienda online ficticia de WineNotFound con packs, referencias y procedimiento de compra."
    />
    <meta name="theme-color" content="#2b1018" />
    <link rel="icon" href={`${baseUrl}favicon.svg`} type="image/svg+xml" />
    <title>Tienda | WineNotFound</title>
  </head>
  <body>
    <SiteHeader />

    <main>
      <section class="page-hero" aria-labelledby="shop-page-title">
        <p class="eyebrow">Tienda online</p>
        <h1 id="shop-page-title">Catálogo de packs y referencias</h1>
        <p>
          La tienda funciona como escaparate de solicitud. El cliente revisa los productos, elige
          una opción y recibe confirmación de disponibilidad antes de pagar.
        </p>
      </section>

      <section class="section shop-section" aria-labelledby="packs-title">
        <div class="section-heading">
          <p class="eyebrow">Packs destacados</p>
          <h2 id="packs-title">Opciones para comprar o regalar</h2>
          <p>
            Los precios y productos son ficticios para el proyecto. El objetivo es mostrar cómo
            funcionaría una tienda de bodega con solicitud previa.
          </p>
        </div>

        <div class="shop-grid">
          {shopItems.map((item) => (
            <article class="product-tile">
              <p>{item.price}</p>
              <h3>{item.title}</h3>
              <span>{item.text}</span>
              <a href={`${baseUrl}#contacto`}>Pedir información</a>
            </article>
          ))}
        </div>
      </section>

      <section class="section collection" aria-labelledby="catalog-title">
        <div class="section-heading">
          <p class="eyebrow">Referencias</p>
          <h2 id="catalog-title">Vinos disponibles</h2>
        </div>

        <div class="wine-grid">
          {wines.map((wine) => <WineCard {...wine} />)}
        </div>
      </section>

      <section class="section" aria-labelledby="buy-title">
        <div class="process-band" aria-labelledby="buy-title">
          <div>
            <p class="eyebrow">Procedimiento de compra</p>
            <h2 id="buy-title">Cómo se realiza un pedido</h2>
          </div>
          <ol class="process-list">
            {purchaseSteps.map((step) => <li>{step}</li>)}
          </ol>
        </div>
      </section>

      <section class="section detail-section" aria-labelledby="conditions-title">
        <div class="section-heading">
          <p class="eyebrow">Condiciones</p>
          <h2 id="conditions-title">Información comercial</h2>
        </div>
        <div class="detail-grid">
          <article class="content-panel">
            <h3>Disponibilidad</h3>
            <p>Las botellas son limitadas y se confirman siempre antes de cerrar el pedido.</p>
          </article>
          <article class="content-panel">
            <h3>Envíos</h3>
            <p>Envíos nacionales ficticios en 48-72 horas laborables tras confirmación.</p>
          </article>
          <article class="content-panel">
            <h3>Regalos</h3>
            <p>Posibilidad de preparar bono de cata o pack personalizado con mensaje.</p>
          </article>
        </div>
      </section>
    </main>

    <SiteFooter />
    <SiteScripts />
  </body>
</html>
