---
import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteScripts from "../components/SiteScripts.astro";
import WineCard from "../components/WineCard.astro";
import { shopItems, subscriptionPlans, subscriptionSteps, wines } from "../data/site";
import "../styles/global.css";

const baseUrl = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Tienda online ficticia de WineNotFound con packs, vinos y suscripción privada The Missing Bottle List."
    />
    <meta name="theme-color" content="#2b1018" />
    <link rel="icon" href={`${baseUrl}favicon.svg`} type="image/svg+xml" />
    <title>Tienda | WineNotFound</title>
  </head>
  <body>
    <SiteHeader />

    <main>
      <section class="page-hero" aria-labelledby="shop-page-title">
        <p class="eyebrow">Tienda online</p>
        <h1 id="shop-page-title">Packs, vinos y suscripción privada</h1>
        <p>
          La tienda funciona como escaparate de solicitud. El cliente revisa productos o planes,
          elige una opción y recibe confirmación de disponibilidad antes de pagar.
        </p>
      </section>

      <section class="section shop-section" aria-labelledby="packs-title">
        <div class="section-heading">
          <p class="eyebrow">Packs destacados</p>
          <h2 id="packs-title">Opciones para comprar, regalar o reservar</h2>
          <p>
            Los precios y productos son ficticios para el proyecto. La tienda permite explicar cómo
            funcionaría una bodega con packs, entradas para experiencias y alta de suscripción.
          </p>
        </div>

        <div class="shop-grid shop-grid-rich">
          {shopItems.map((item) => (
            <article class="product-tile">
              <p>{item.price}</p>
              <h3>{item.title}</h3>
              <span>{item.text}</span>
              <ul class="compact-list">
                {item.benefits.map((benefit) => <li>{benefit}</li>)}
              </ul>
              <a href={`${baseUrl}#contacto`}>Pedir información</a>
            </article>
          ))}
        </div>
      </section>

      <section class="section collection" aria-labelledby="catalog-title">
        <div class="section-heading">
          <p class="eyebrow">Referencias</p>
          <h2 id="catalog-title">Vinos disponibles</h2>
          <p>
            Cada referencia se presenta con añada, crianza, producción aproximada y perfil de sabor.
          </p>
        </div>

        <div class="wine-grid">
          {wines.map((wine) => <WineCard {...wine} />)}
        </div>
      </section>

      <section class="section subscription-section" id="suscripcion" aria-labelledby="subscription-title">
        <div class="section-heading">
          <p class="eyebrow">Suscripción</p>
          <h2 id="subscription-title">The Missing Bottle List</h2>
          <p>
            La suscripción está pensada para clientes que quieren recibir selección de vinos,
            preventas y ventajas en experiencias sin revisar la web cada semana.
          </p>
        </div>

        <div class="subscription-layout">
          <figure class="subscription-media">
            <img src={`${baseUrl}images/gallery-subscription.png`} alt="Caja de suscripción WineNotFound" loading="lazy" />
            <figcaption>Caja de temporada con notas de cata, acceso anticipado y cupo prioritario.</figcaption>
          </figure>
          <div class="subscription-plans">
            {subscriptionPlans.map((plan) => (
              <article class="product-tile subscription-plan">
                <p>{plan.price}</p>
                <h3>{plan.title}</h3>
                <span>{plan.text}</span>
                <ul class="compact-list">
                  {plan.benefits.map((benefit) => <li>{benefit}</li>)}
                </ul>
                <a href={`${baseUrl}#contacto`}>Solicitar alta</a>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="section" aria-labelledby="subscribe-title">
        <div class="process-band" aria-labelledby="subscribe-title">
          <div>
            <p class="eyebrow">Procedimiento</p>
            <h2 id="subscribe-title">Cómo suscribirse</h2>
          </div>
          <ol class="process-list">
            {subscriptionSteps.map((step) => <li>{step}</li>)}
          </ol>
        </div>
      </section>

      <section class="section detail-section" aria-labelledby="conditions-title">
        <div class="section-heading">
          <p class="eyebrow">Condiciones</p>
          <h2 id="conditions-title">Información comercial</h2>
        </div>
        <div class="detail-grid">
          <article class="content-panel">
            <h3>Disponibilidad</h3>
            <p>Las botellas son limitadas y se confirman siempre antes de cerrar el pedido.</p>
          </article>
          <article class="content-panel">
            <h3>Envíos</h3>
            <p>Envíos nacionales ficticios en 48-72 horas laborables tras confirmación.</p>
          </article>
          <article class="content-panel">
            <h3>Regalos</h3>
            <p>Posibilidad de preparar bono de cata, pack personalizado o alta de suscripción con mensaje.</p>
          </article>
        </div>
      </section>
    </main>

    <SiteFooter />
    <SiteScripts />
  </body>
</html>
