---
import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteScripts from "../components/SiteScripts.astro";
import ExperienceCard from "../components/ExperienceCard.astro";
import { experiences, reservationSteps } from "../data/site";
import "../styles/global.css";

const baseUrl = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Reserva catas, comidas y cenas en la bodega WineNotFound con horarios según disponibilidad."
    />
    <meta name="theme-color" content="#2b1018" />
    <link rel="icon" href={`${baseUrl}favicon.svg`} type="image/svg+xml" />
    <title>Reservar | WineNotFound</title>
  </head>
  <body>
    <SiteHeader />

    <main>
      <section
        class="booking-hero"
        aria-labelledby="booking-title"
        style={`--booking-bg: url("${baseUrl}images/gallery-restaurant.png")`}
      >
        <div class="booking-card">
          <p class="eyebrow">Reservas</p>
          <h1 id="booking-title">Reserva cata, comida o cena</h1>
          <p>Ctra. Nacional 232, 26330 Briones, La Rioja, España</p>

          <form class="booking-form" data-booking-form>
            <div class="booking-stepper" data-quantity-control>
              <label for="adults">Adultos</label>
              <div class="stepper-row">
                <button type="button" data-step="-1" aria-label="Restar adulto">−</button>
                <input id="adults" name="adults" type="number" value="2" min="1" max="12" readonly />
                <button type="button" data-step="1" aria-label="Sumar adulto">+</button>
              </div>
            </div>

            <div class="booking-stepper" data-quantity-control>
              <label for="children">
                Niños
                <span>Hasta 12 años</span>
              </label>
              <div class="stepper-row">
                <button type="button" data-step="-1" aria-label="Restar niño">−</button>
                <input id="children" name="children" type="number" value="0" min="0" max="8" readonly />
                <button type="button" data-step="1" aria-label="Sumar niño">+</button>
              </div>
            </div>

            <label class="booking-field">
              Fecha
              <input type="date" name="date" data-booking-date required />
            </label>

            <fieldset class="booking-options" data-booking-type-options>
              <legend>Tipo de reserva</legend>
              <label>
                <input type="radio" name="slot" value="cata" data-booking-type checked />
                <span>Cata</span>
              </label>
              <label>
                <input type="radio" name="slot" value="comida" data-booking-type />
                <span>Comida</span>
              </label>
              <label>
                <input type="radio" name="slot" value="cena" data-booking-type />
                <span>Cena</span>
              </label>
            </fieldset>

            <fieldset class="booking-times" aria-describedby="booking-time-help">
              <legend>Horario disponible</legend>
              <div class="booking-time-grid" data-booking-times></div>
              <p class="booking-time-help" id="booking-time-help" data-booking-time-help>
                Elige primero tipo y fecha para ver los turnos libres y bloqueados.
              </p>
            </fieldset>

            <p class="booking-availability-note" data-booking-availability-note aria-live="polite"></p>

            <button class="button button-primary" type="submit">Continuar</button>
            <p class="form-status" data-booking-status role="status" aria-live="polite"></p>
          </form>

          <div class="booking-actions">
            <a href="#experiencias">Ver experiencias</a>
            <a href={`${baseUrl}tienda/#suscripcion`}>Ver suscripción</a>
          </div>

          <p class="booking-phone">Llámenos al <a href="tel:+34910404404">+34 910 404 404</a> si tiene cualquier duda.</p>
        </div>
      </section>

      <section class="section" aria-labelledby="booking-process-title">
        <div class="process-band">
          <div>
            <p class="eyebrow">Procedimiento</p>
            <h2 id="booking-process-title">Cómo se confirma una reserva</h2>
          </div>
          <ol class="process-list">
            {reservationSteps.map((step) => <li>{step}</li>)}
          </ol>
        </div>
      </section>

      <section class="section experiences" id="experiencias" aria-labelledby="booking-experiences-title">
        <div class="section-heading">
          <p class="eyebrow">Opciones reservables</p>
          <h2 id="booking-experiences-title">Cata, comida o cena</h2>
          <p>
            Las reservas directas se limitan a cata, comida y cena. Los horarios aparecen
            liberados o bloqueados según la disponibilidad de la fecha elegida.
          </p>
        </div>

        <div class="experience-grid">
          {experiences.map((experience) => <ExperienceCard {...experience} />)}
        </div>
      </section>
    </main>

    <SiteFooter />
    <SiteScripts />
  </body>
</html>
