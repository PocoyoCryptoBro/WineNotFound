---
import SiteScripts from "../components/SiteScripts.astro";
import "../styles/global.css";

const baseUrl = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Reserva catas y comidas en WineNotFound con disponibilidad de lunes a domingo, excepto miércoles."
    />
    <meta name="theme-color" content="#2b1018" />
    <link rel="icon" href={`${baseUrl}favicon.svg`} type="image/svg+xml" />
    <title>Reservar | WineNotFound</title>
  </head>
  <body>
    <main>
      <section
        class="booking-hero"
        aria-labelledby="booking-title"
        style={`--booking-bg: url("${baseUrl}images/gallery-restaurant.png")`}
      >
        <div class="booking-card booking-card-wide" data-booking-card data-active-panel="details">
          <form class="booking-form" data-booking-form>
            <section class="booking-panel is-active" data-booking-panel="details">
              <div class="booking-heading">
                <h1 id="booking-title">Reserve en La Vieja Bodega.</h1>
                <p>Av. de La Rioja, 17. Casalarreina</p>
              </div>

              <div class="booking-stepper" data-quantity-control>
                <label for="adults"><span class="booking-icon" aria-hidden="true">◎</span> Adultos</label>
                <div class="stepper-row">
                  <button type="button" data-step="-1" aria-label="Restar adulto">-</button>
                  <input id="adults" name="adults" type="number" value="2" min="1" max="12" readonly />
                  <button type="button" data-step="1" aria-label="Sumar adulto">+</button>
                </div>
              </div>

              <div class="booking-stepper" data-quantity-control>
                <label for="children">
                  <span class="booking-icon" aria-hidden="true">◎</span> Niños
                  <small>Hasta 12 años</small>
                </label>
                <div class="stepper-row">
                  <button type="button" data-step="-1" aria-label="Restar niño">-</button>
                  <input id="children" name="children" type="number" value="0" min="0" max="8" readonly />
                  <button type="button" data-step="1" aria-label="Sumar niño">+</button>
                </div>
              </div>

              <fieldset class="booking-date-options">
                <legend><span aria-hidden="true">▦</span> Fecha</legend>
                <div class="booking-date-grid" data-booking-date-options></div>
              </fieldset>

              <fieldset class="booking-options" data-booking-type-options>
                <legend><span aria-hidden="true">◷</span> Reserva para</legend>
                <label>
                  <input type="radio" name="slot" value="comida" data-booking-type checked />
                  <span>COMIDA<small>13:30 - 15:30</small></span>
                </label>
              </fieldset>

              <button class="button button-primary booking-main-button" type="button" data-booking-continue>CONTINUAR</button>

              <div class="booking-actions">
                <a href={`${baseUrl}tienda/#suscripcion`}>VER EXPERIENCIAS PARA REGALAR</a>
                <a href={`${baseUrl}tienda/#suscripcion`}>CANJEAR TARJETA REGALO O CÓDIGO</a>
              </div>

              <p class="booking-phone">Llámenos al <a href="tel:+34941324254">941 32 42 54</a> si tiene cualquier duda.</p>
            </section>

            <section class="booking-panel" data-booking-panel="times" hidden>
              <p class="booking-summary-line" data-booking-summary></p>
              <h2>Elija un horario.</h2>
              <div class="booking-time-grid booking-time-grid-large" data-booking-times></div>
              <button class="button button-outline booking-back-button" type="button" data-booking-back>RETROCEDER</button>
              <p class="booking-phone">Llámenos al <a href="tel:+34941324254">941 32 42 54</a> si tiene cualquier duda.</p>
            </section>

            <section class="booking-panel" data-booking-panel="guest" hidden>
              <h2>Ingrese sus datos personales.</h2>
              <div class="booking-confirm-summary">
                <span><small aria-hidden="true">▦</small><strong data-confirm-date></strong></span>
                <span><small aria-hidden="true">◷</small><strong data-confirm-time></strong></span>
                <span><small aria-hidden="true">◎</small><strong data-confirm-people></strong></span>
                <button class="checkout-back" type="button" data-booking-modify>MODIFICAR</button>
              </div>

              <div class="booking-guest-fields">
                <input type="text" name="name" autocomplete="name" placeholder="Nombre completo" required />
                <input type="email" name="email" autocomplete="email" placeholder="Email" required />
                <div class="phone-row">
                  <span>🇪🇸 +34</span>
                  <input type="tel" name="phone" autocomplete="tel" placeholder="Teléfono" required />
                </div>
                <input
                  type="text"
                  name="postal"
                  inputmode="numeric"
                  autocomplete="postal-code"
                  placeholder="Código postal"
                  required
                />
                <fieldset class="allergy-toggle">
                  <legend>¿Alguna persona tiene alergias y/o intolerancias?</legend>
                  <div>
                    <label><input type="radio" name="allergies" value="no" checked /> NO</label>
                    <label><input type="radio" name="allergies" value="si" /> SÍ</label>
                  </div>
                </fieldset>
                <button class="special-requests-button" type="button">AÑADIR PETICIONES ESPECIALES</button>
                <label class="booking-checkbox">
                  <input type="checkbox" name="terms" required />
                  <span>Acepto las <a href={`${baseUrl}aviso-legal/`}>Condiciones de Uso</a> y <a href={`${baseUrl}aviso-legal/`}>Política de Privacidad</a>.</span>
                </label>
                <label class="booking-checkbox">
                  <input type="checkbox" name="newsletter" />
                  Quiero recibir información comercial por email y/o SMS.
                </label>
                <label class="booking-checkbox">
                  <input type="checkbox" name="reminder" />
                  Recordarme para la próxima reserva.
                </label>
              </div>

              <button class="button button-primary booking-confirm-button" type="submit">CONFIRMAR RESERVA</button>
              <p class="booking-phone">Llámenos al <a href="tel:+34941324254">941 32 42 54</a> si tiene cualquier duda.</p>
              <p class="booking-legal-note">
                Recogemos datos anónimos, sin posibilidad de identificación personal, para cumplir con
                las obligaciones de información del restaurante respecto a alérgenos, y/o las posibles
                necesidades de accesibilidad. Por tanto, sobre esta información, no es de aplicación la
                normativa europea de protección de datos personales (Artículo 2, Artículo 4, Apartados 1 y
                5 y Considerandos 14, 15, 26, 27, 29 y 30 del RGPD).
              </p>
            </section>
            <p class="form-status" data-booking-status role="status" aria-live="polite"></p>
          </form>
        </div>
      </section>
    </main>
    <SiteScripts />
  </body>
</html>
