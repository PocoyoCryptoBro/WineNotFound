---
import GoogleTag from "../components/GoogleTag.astro";
import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteScripts from "../components/SiteScripts.astro";
import { blogPosts } from "../data/site";
import "../styles/global.css";

const baseUrl = import.meta.env.BASE_URL;
const featuredPost = blogPosts[0];
const restPosts = blogPosts.slice(1);
---

<!doctype html>
<html lang="es">
  <head>
    <GoogleTag />
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Blog de WineNotFound con artículos sobre vino, restaurante, bodega, vendimia y suscripción."
    />
    <meta name="theme-color" content="#2b1018" />
    <link rel="icon" href={`${baseUrl}favicon.svg`} type="image/svg+xml" />
    <title>Blog | WineNotFound</title>
  </head>
  <body>
    <SiteHeader />

    <main>
      <section class="page-hero" aria-labelledby="blog-page-title">
        <p class="eyebrow">Blog</p>
        <h1 id="blog-page-title">Historias de vino, bodega y restaurante</h1>
        <p>
          Artículos para explicar mejor el producto, la forma de trabajar y las experiencias de WineNotFound.
        </p>
      </section>

      <section class="section blog-feature" aria-labelledby="featured-blog-title">
        <figure>
          <img src={`${baseUrl}${featuredPost.image}`} alt={featuredPost.title} loading="lazy" />
        </figure>
        <article>
          <p class="eyebrow">{featuredPost.category} · {featuredPost.date} · {featuredPost.readTime}</p>
          <h2 id="featured-blog-title">{featuredPost.title}</h2>
          <p>{featuredPost.text}</p>
          {featuredPost.content.map((paragraph) => <p>{paragraph}</p>)}
        </article>
      </section>

      <section class="section blog-section" aria-labelledby="all-posts-title">
        <div class="section-heading">
          <p class="eyebrow">Publicaciones</p>
          <h2 id="all-posts-title">Más artículos</h2>
        </div>

        <div class="blog-grid">
          {restPosts.map((post) => (
            <article class="blog-article-card">
              <img src={`${baseUrl}${post.image}`} alt={post.title} loading="lazy" />
              <div>
                <span>{post.category} · {post.date} · {post.readTime}</span>
                <h3>{post.title}</h3>
                <p>{post.text}</p>
                {post.content.map((paragraph) => <p>{paragraph}</p>)}
              </div>
            </article>
          ))}
        </div>
      </section>
    </main>

    <SiteFooter />
    <SiteScripts />
  </body>
</html>
