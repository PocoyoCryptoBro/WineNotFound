---
const baseUrl = import.meta.env.BASE_URL;

const navItems = [
  { href: baseUrl, label: "Inicio" },
  { href: `${baseUrl}sobre-nosotros/`, label: "Sobre nosotros" },
  { href: `${baseUrl}tienda/`, label: "Tienda" },
  { href: `${baseUrl}faq/`, label: "FAQ" },
  { href: `${baseUrl}#contacto`, label: "Contacto" },
];
---

<header class="site-header" data-header>
  <a class="brand" href={baseUrl} aria-label="WineNotFound inicio">
    <span class="brand-mark">WNF</span>
    <span>WineNotFound</span>
  </a>

  <button class="nav-toggle" type="button" aria-expanded="false" aria-controls="site-nav" aria-label="Abrir menú">
    <span></span>
    <span></span>
    <span></span>
  </button>

  <nav class="site-nav" id="site-nav" aria-label="Navegación principal">
    {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
  </nav>
</header>
