---
const navItems = [
  { href: "#inicio", label: "Inicio" },
  { href: "#nosotros", label: "Nosotros" },
  { href: "#productos", label: "Productos" },
  { href: "#faq", label: "FAQ" },
  { href: "#contacto", label: "Contacto" },
];
---

<header class="site-header" data-header>
  <a class="brand" href="#inicio" aria-label="WineNotFound inicio">
    <span class="brand-mark">WNF</span>
    <span>WineNotFound</span>
  </a>

  <button class="nav-toggle" type="button" aria-expanded="false" aria-controls="site-nav" aria-label="Abrir menu">
    <span></span>
    <span></span>
    <span></span>
  </button>

  <nav class="site-nav" id="site-nav" aria-label="Navegacion principal">
    {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
  </nav>
</header>
