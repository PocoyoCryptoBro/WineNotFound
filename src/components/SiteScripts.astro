<script>
  const header = document.querySelector("[data-header]");
  const navToggle = document.querySelector<HTMLButtonElement>(".nav-toggle");
  const siteNav = document.querySelector<HTMLElement>("[data-site-nav]");
  const navLinks = [...document.querySelectorAll<HTMLAnchorElement>(".site-nav a")];
  const filterButtons = [...document.querySelectorAll<HTMLButtonElement>("[data-filter]")];
  const wineCards = [...document.querySelectorAll<HTMLElement>(".wine-card")];
  const reservationForm = document.querySelector<HTMLFormElement>("[data-reservation-form]");
  const formStatus = document.querySelector("[data-form-status]");
  const bookingForm = document.querySelector<HTMLFormElement>("[data-booking-form]");
  const bookingCard = document.querySelector<HTMLElement>("[data-booking-card]");
  const bookingStatus = document.querySelector("[data-booking-status]");
  const bookingTypeInputs = [...document.querySelectorAll<HTMLInputElement>("[data-booking-type]")];
  const bookingDateOptions = document.querySelector<HTMLElement>("[data-booking-date-options]");
  const bookingPanels = [...document.querySelectorAll<HTMLElement>("[data-booking-panel]")];
  const bookingContinue = document.querySelector<HTMLButtonElement>("[data-booking-continue]");
  const bookingBack = document.querySelector<HTMLButtonElement>("[data-booking-back]");
  const bookingModify = document.querySelector<HTMLButtonElement>("[data-booking-modify]");
  const bookingSummary = document.querySelector<HTMLElement>("[data-booking-summary]");
  const bookingTimes = document.querySelector<HTMLElement>("[data-booking-times]");
  const confirmDate = document.querySelector<HTMLElement>("[data-confirm-date]");
  const confirmTime = document.querySelector<HTMLElement>("[data-confirm-time]");
  const confirmPeople = document.querySelector<HTMLElement>("[data-confirm-people]");
  const successDate = document.querySelector<HTMLElement>("[data-success-date]");
  const successTime = document.querySelector<HTMLElement>("[data-success-time]");
  const successPeople = document.querySelector<HTMLElement>("[data-success-people]");
  const successModify = document.querySelector<HTMLButtonElement>("[data-success-modify]");
  const quantityControls = [...document.querySelectorAll<HTMLElement>("[data-quantity-control]")];
  const cartAddButtons = [...document.querySelectorAll<HTMLButtonElement>("[data-cart-add]")];
  const cartBuyButtons = [...document.querySelectorAll<HTMLButtonElement>("[data-cart-buy]")];
  const cartList = document.querySelector<HTMLUListElement>("[data-cart-list]");
  const cartEmpty = document.querySelector<HTMLElement>("[data-cart-empty]");
  const cartTotal = document.querySelector<HTMLElement>("[data-cart-total]");
  const cartCounts = [...document.querySelectorAll<HTMLElement>("[data-cart-count]")];
  const cartDropdown = document.querySelector<HTMLElement>("[data-cart-dropdown]");
  const cartToggle = document.querySelector<HTMLButtonElement>("[data-cart-toggle]");
  const cartClose = document.querySelector<HTMLButtonElement>("[data-cart-close]");
  const cartClear = document.querySelector<HTMLButtonElement>("[data-cart-clear]");
  const cartCheckout = document.querySelector<HTMLButtonElement>("[data-cart-checkout]");
  const checkoutPage = document.querySelector<HTMLElement>("[data-checkout-page]");
  const checkoutBack = document.querySelector<HTMLButtonElement>("[data-checkout-back]");
  const checkoutForm = document.querySelector<HTMLFormElement>("[data-checkout-form]");
  const checkoutSummary = document.querySelector<HTMLElement>("[data-checkout-summary]");
  const checkoutSubmit = document.querySelector<HTMLButtonElement>("[data-checkout-submit]");
  const checkoutStatus = document.querySelector<HTMLElement>("[data-checkout-status]");
  const year = document.querySelector("[data-year]");

  if (year) year.textContent = new Date().getFullYear().toString();

  const updateHeaderState = () => {
    const homePath = new URL(document.querySelector<HTMLAnchorElement>(".brand")?.href ?? "/", window.location.href)
      .pathname;
    header?.classList.toggle("is-scrolled", window.scrollY > 24 || window.location.pathname !== homePath);
  };

  updateHeaderState();
  window.addEventListener("scroll", updateHeaderState, { passive: true });

  const mobileMenuQuery = window.matchMedia("(max-width: 920px)");

  const syncMenuA11y = (isOpen: boolean) => {
    navToggle?.setAttribute("aria-expanded", String(isOpen));
    navToggle?.setAttribute("aria-label", isOpen ? "Cerrar menú" : "Abrir menú");
    siteNav?.setAttribute("aria-hidden", String(mobileMenuQuery.matches && !isOpen));
  };

  const closeMenu = () => {
    header?.classList.remove("is-menu-open");
    document.body.classList.remove("nav-open");
    syncMenuA11y(false);
  };

  const openMenu = () => {
    header?.classList.add("is-menu-open");
    document.body.classList.add("nav-open");
    syncMenuA11y(true);
  };

  syncMenuA11y(false);

  navToggle?.addEventListener("click", () => {
    const isOpen = navToggle.getAttribute("aria-expanded") === "true";
    if (isOpen) {
      closeMenu();
    } else {
      openMenu();
    }
  });

  navLinks.forEach((link) => {
    link.addEventListener("click", () => {
      closeMenu();
    });
  });

  siteNav?.addEventListener("click", (event) => {
    if (event.target === siteNav) closeMenu();
  });

  window.addEventListener("keydown", (event) => {
    if (event.key === "Escape") {
      closeMenu();
      closeCartDropdown();
    }
  });

  mobileMenuQuery.addEventListener("change", () => {
    closeMenu();
    syncMenuA11y(false);
  });

  filterButtons.forEach((button) => {
    button.addEventListener("click", () => {
      const filter = button.dataset.filter ?? "all";

      filterButtons.forEach((current) => current.classList.toggle("is-active", current === button));
      wineCards.forEach((card) => {
        const types = card.dataset.type?.split(" ") ?? [];
        card.classList.toggle("is-hidden", filter !== "all" && !types.includes(filter));
      });
    });
  });

  const localSectionLinks = navLinks
    .map((link) => {
      const href = link.getAttribute("href") ?? "";
      if (href.startsWith("#")) return { link, hash: href };

      try {
        const url = new URL(link.href);
        const samePage = url.origin === window.location.origin && url.pathname === window.location.pathname;
        return samePage && url.hash ? { link, hash: url.hash } : null;
      } catch {
        return null;
      }
    })
    .filter((item): item is { link: HTMLAnchorElement; hash: string } => Boolean(item));

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;

        localSectionLinks.forEach((item) => {
          item.link.classList.toggle("is-active", item.hash === `#${entry.target.id}`);
        });
      });
    },
    {
      rootMargin: "-45% 0px -45% 0px",
      threshold: 0,
    },
  );

  localSectionLinks.forEach((item) => {
    const section = document.querySelector(item.hash);
    if (section) observer.observe(section);
  });

  if (reservationForm) {
    reservationForm.addEventListener("submit", (event) => {
      event.preventDefault();
      const formData = new FormData(reservationForm);
      const rawName = formData.get("name");
      const name = rawName?.toString().trim().split(" ")[0] || "Gracias";

      if (formStatus) {
        formStatus.textContent = `${name}, solicitud recibida. Te escribiremos para responder a tu consulta.`;
      }

      reservationForm.reset();
    });
  }

  quantityControls.forEach((control) => {
    const input = control.querySelector<HTMLInputElement>("input");
    const buttons = [...control.querySelectorAll<HTMLButtonElement>("[data-step]")];

    buttons.forEach((button) => {
      button.addEventListener("click", () => {
        if (!input) return;

        const step = Number(button.dataset.step ?? 0);
        const min = Number(input.min || 0);
        const max = Number(input.max || 99);
        const nextValue = Math.min(max, Math.max(min, Number(input.value || 0) + step));
        input.value = nextValue.toString();
      });
    });
  });

  type BookingType = "cata" | "comida";

  type BookingDay = {
    date: Date;
    iso: string;
    dayLabel: string;
    numberLabel: string;
    monthLabel: string;
    isClosed: boolean;
  };

  const bookingLabels: Record<BookingType, string> = {
    cata: "Cata",
    comida: "Comida",
  };

  const bookingSchedules: Record<BookingType, string[]> = {
    cata: [
      "10:30",
      "11:00",
      "11:30",
      "12:00",
      "12:30",
      "13:00",
      "13:30",
      "14:00",
      "14:30",
      "15:00",
      "15:30",
      "16:00",
      "16:30",
      "17:00",
    ],
    comida: ["13:30", "13:45", "14:00", "14:15", "14:30", "14:45", "15:00", "15:15", "15:30"],
  };

  const toIsoDate = (date: Date) => {
    const offsetDate = new Date(date.getTime() - date.getTimezoneOffset() * 60000);
    return offsetDate.toISOString().slice(0, 10);
  };

  const getSelectedBookingType = (): BookingType =>
    bookingTypeInputs.find((input) => input.checked)?.value === "comida" ? "comida" : "cata";

  const getBookingPeople = () => {
    const adults = Number(bookingForm?.querySelector<HTMLInputElement>("#adults")?.value || 1);
    const children = Number(bookingForm?.querySelector<HTMLInputElement>("#children")?.value || 0);
    const total = adults + children;
    return { adults, children, total };
  };

  const hashBooking = (value: string) =>
    [...value].reduce((sum, character, index) => sum + character.charCodeAt(0) * (index + 3), 0);

  const isClosedDate = (date: Date) => date.getDay() === 3;

  const getAvailableTimes = (iso: string, type: BookingType) => {
    const date = new Date(`${iso}T12:00:00`);
    if (isClosedDate(date)) return [];

    return bookingSchedules[type];
  };

  const formatBookingDate = (date: Date) => {
    const weekday = new Intl.DateTimeFormat("es-ES", { weekday: "short" }).format(date).replace(".", "");
    const month = new Intl.DateTimeFormat("es-ES", { month: "short" }).format(date).replace(".", "");
    return `${weekday}., ${date.getDate()} ${month}.`;
  };

  const getDateButtonLabel = (date: Date, todayIso: string): BookingDay => {
    const iso = toIsoDate(date);
    const weekday = new Intl.DateTimeFormat("es-ES", { weekday: "short" }).format(date).replace(".", "");
    const month = new Intl.DateTimeFormat("es-ES", { month: "short" }).format(date).replace(".", "");

    return {
      date,
      iso,
      dayLabel: iso === todayIso ? "HOY" : `${weekday.toUpperCase()}.`,
      numberLabel: date.getDate().toString(),
      monthLabel: month.toUpperCase(),
      isClosed: isClosedDate(date),
    };
  };

  let bookingDays: BookingDay[] = [];
  let selectedBookingDate = "";
  let selectedBookingTime = "";

  const setBookingPanel = (panel: "details" | "times" | "guest" | "success") => {
    if (bookingCard) bookingCard.dataset.activePanel = panel;
    document.body.classList.toggle("booking-success-active", panel === "success");
    bookingPanels.forEach((current) => {
      const active = current.dataset.bookingPanel === panel;
      current.hidden = !active;
      current.classList.toggle("is-active", active);
    });
  };

  const renderBookingDateButtons = () => {
    if (!bookingDateOptions) return;

    bookingDateOptions.replaceChildren();

    bookingDays.forEach((day) => {
      const button = document.createElement("button");
      button.type = "button";
      button.className = "booking-date-button";
      button.dataset.date = day.iso;
      button.classList.toggle("is-active", day.iso === selectedBookingDate);
      button.classList.toggle("is-closed", day.isClosed);
      button.setAttribute("aria-pressed", String(day.iso === selectedBookingDate));

      const dayLabel = document.createElement("span");
      dayLabel.textContent = day.dayLabel;
      const numberLabel = document.createElement("strong");
      numberLabel.textContent = day.numberLabel;
      const monthLabel = document.createElement("small");
      monthLabel.textContent = day.monthLabel;

      button.append(dayLabel, numberLabel, monthLabel);
      button.addEventListener("click", () => {
        selectedBookingDate = day.iso;
        if (bookingStatus) bookingStatus.textContent = "";
        renderBookingDateButtons();
      });

      bookingDateOptions.append(button);
    });

    const moreButton = document.createElement("button");
    moreButton.type = "button";
    moreButton.className = "booking-date-button";
    moreButton.innerHTML = "<span>&nbsp;</span><strong>...</strong><small>&nbsp;</small>";
    moreButton.addEventListener("click", () => {
      const lastDay = bookingDays.at(-1)?.date ?? new Date();
      const nextDay = new Date(lastDay);
      nextDay.setDate(lastDay.getDate() + 1);
      bookingDays.push(getDateButtonLabel(nextDay, bookingDays[0]?.iso ?? toIsoDate(new Date())));
      renderBookingDateButtons();
    });
    bookingDateOptions.append(moreButton);
  };

  const renderBookingTimes = () => {
    if (!bookingTimes) return;

    const type = getSelectedBookingType();
    const times = getAvailableTimes(selectedBookingDate, type);
    const day = bookingDays.find((item) => item.iso === selectedBookingDate);
    const { total } = getBookingPeople();

    bookingTimes.replaceChildren();

    if (bookingSummary && day) {
      bookingSummary.innerHTML = `
        <svg class="booking-icon-svg" aria-hidden="true"><use href="/images/reference/restoo-sprites.svg#date"></use></svg>${formatBookingDate(day.date)}
        <svg class="booking-icon-svg" aria-hidden="true"><use href="/images/reference/restoo-sprites.svg#time"></use></svg>${bookingLabels[type]}
        <svg class="booking-icon-svg" aria-hidden="true"><use href="/images/reference/restoo-sprites.svg#guest"></use></svg>${total} ${total === 1 ? "Persona" : "Personas"}
      `;
    }

    times.forEach((time) => {
      const button = document.createElement("button");
      button.type = "button";
      button.className = "booking-time-button";
      button.textContent = time;
      button.addEventListener("click", () => {
        selectedBookingTime = time;
        const peopleLabel = `${total} ${total === 1 ? "Persona" : "Personas"}`;
        if (confirmDate && day) confirmDate.textContent = formatBookingDate(day.date);
        if (confirmTime) confirmTime.textContent = time;
        if (confirmPeople) confirmPeople.textContent = peopleLabel;
        if (bookingStatus) bookingStatus.textContent = "";
        setBookingPanel("guest");
      });
      bookingTimes.append(button);
    });
  };

  if (bookingForm) {
    const today = new Date();
    const todayIso = toIsoDate(today);
    bookingDays = Array.from({ length: 6 }, (_, index) => {
      const date = new Date(today);
      date.setDate(today.getDate() + index);
      return getDateButtonLabel(date, todayIso);
    });

    selectedBookingDate = bookingDays.find((day) => !day.isClosed)?.iso ?? bookingDays[0]?.iso ?? "";
    renderBookingDateButtons();

    bookingTypeInputs.forEach((input) => {
      input.addEventListener("change", () => {
        if (bookingStatus) bookingStatus.textContent = "";
      });
    });

    bookingContinue?.addEventListener("click", () => {
      const day = bookingDays.find((item) => item.iso === selectedBookingDate);
      const type = getSelectedBookingType();
      const availableTimes = getAvailableTimes(selectedBookingDate, type);

      if (day?.isClosed || !availableTimes.length) {
        if (bookingStatus) {
          bookingStatus.textContent = day?.isClosed
            ? "No hay disponibilidad: los miércoles cerramos por descanso del personal."
            : "No hay disponibilidad para ese día. Prueba otra fecha.";
        }
        return;
      }

      if (bookingStatus) bookingStatus.textContent = "";
      renderBookingTimes();
      setBookingPanel("times");
    });

    bookingBack?.addEventListener("click", () => {
      if (bookingStatus) bookingStatus.textContent = "";
      setBookingPanel("details");
    });

    bookingModify?.addEventListener("click", () => {
      if (bookingStatus) bookingStatus.textContent = "";
      setBookingPanel("details");
    });

    successModify?.addEventListener("click", () => {
      if (bookingStatus) bookingStatus.textContent = "";
      setBookingPanel("details");
    });

    bookingForm.addEventListener("submit", (event) => {
      event.preventDefault();
      const day = bookingDays.find((item) => item.iso === selectedBookingDate);
      const { total } = getBookingPeople();

      if (!selectedBookingTime || !day) {
        if (bookingStatus) bookingStatus.textContent = "Elige día y horario antes de confirmar.";
        setBookingPanel("details");
        return;
      }

      if (successDate) successDate.textContent = formatBookingDate(day.date);
      if (successTime) successTime.textContent = selectedBookingTime;
      if (successPeople) successPeople.textContent = `${total} ${total === 1 ? "Persona" : "Personas"}`;
      if (bookingStatus) bookingStatus.textContent = "";
      setBookingPanel("success");
    });
  }

  type CartItem = {
    id: string;
    name: string;
    price: number;
    cycle: string;
    quantity: number;
  };

  const CART_STORAGE_KEY = "winenotfound-cart";

  const readStoredCart = () => {
    try {
      const stored = window.localStorage.getItem(CART_STORAGE_KEY);
      if (!stored) return [];

      const parsed = JSON.parse(stored) as CartItem[];
      if (!Array.isArray(parsed)) return [];

      return parsed.filter(
        (item) =>
          item &&
          typeof item.id === "string" &&
          typeof item.name === "string" &&
          Number.isFinite(item.price) &&
          Number.isFinite(item.quantity),
      );
    } catch {
      return [];
    }
  };

  const cart = new Map<string, CartItem>(readStoredCart().map((item) => [item.id, item]));
  const moneyFormatter = new Intl.NumberFormat("es-ES", { style: "currency", currency: "EUR" });

  const persistCart = () => {
    try {
      window.localStorage.setItem(CART_STORAGE_KEY, JSON.stringify([...cart.values()]));
    } catch {
      // Cart still works in-memory if storage is unavailable.
    }
  };

  const getCartTotals = () => {
    const items = [...cart.values()];
    const count = items.reduce((total, item) => total + item.quantity, 0);
    const total = items.reduce((sum, item) => sum + item.price * item.quantity, 0);
    return { items, count, total };
  };

  const setCheckoutEnabled = (enabled: boolean) => {
    if (cartClear) cartClear.disabled = !enabled;
    if (cartCheckout) cartCheckout.disabled = !enabled;
    if (checkoutSubmit) checkoutSubmit.disabled = !enabled;
  };

  const openCartDropdown = () => {
    if (!cartDropdown) return;

    cartDropdown.hidden = false;
    cartDropdown.classList.add("is-open");
    cartToggle?.setAttribute("aria-expanded", "true");
  };

  const closeCartDropdown = () => {
    if (!cartDropdown) return;

    cartDropdown.classList.remove("is-open");
    cartDropdown.hidden = true;
    cartToggle?.setAttribute("aria-expanded", "false");
  };

  const getCheckoutUrl = () => {
    const baseHref = document.querySelector<HTMLAnchorElement>(".brand")?.href ?? `${window.location.origin}/`;
    return new URL("finalizar-compra/", baseHref).href;
  };

  const goToCheckoutPage = () => {
    const { items } = getCartTotals();
    if (!items.length) return;

    closeCartDropdown();
    window.location.href = getCheckoutUrl();
  };

  const closeCheckoutPage = () => {
    if (!checkoutPage) return;
    if (checkoutPage.hasAttribute("hidden")) {
      checkoutPage.classList.remove("is-open");
      checkoutPage.hidden = true;
    }
  };

  const renderCart = () => {
    const { items, count, total } = getCartTotals();
    const hasItems = items.length > 0;
    persistCart();

    cartList?.replaceChildren();
    cartEmpty?.toggleAttribute("hidden", hasItems);
    setCheckoutEnabled(hasItems);

    cartCounts.forEach((cartCount) => {
      cartCount.textContent = `${count} ${count === 1 ? "producto" : "productos"}`;
    });

    if (cartTotal) {
      cartTotal.textContent = moneyFormatter.format(total);
    }

    if (checkoutSummary) {
      checkoutSummary.textContent = hasItems
        ? `${count} ${count === 1 ? "producto" : "productos"} en el carrito · Total ${moneyFormatter.format(total)}`
        : "Selecciona productos para activar el pago.";
    }

    items.forEach((item) => {
      const row = document.createElement("li");
      row.className = "cart-item";

      const copy = document.createElement("div");
      const title = document.createElement("strong");
      title.textContent = item.name;
      const meta = document.createElement("span");
      meta.textContent = `${moneyFormatter.format(item.price)} · ${item.cycle}`;
      copy.append(title, meta);

      const controls = document.createElement("div");
      controls.className = "cart-controls";

      const decrease = document.createElement("button");
      decrease.type = "button";
      decrease.textContent = "−";
      decrease.setAttribute("aria-label", `Restar ${item.name}`);
      decrease.addEventListener("click", () => {
        if (item.quantity <= 1) {
          cart.delete(item.id);
        } else {
          item.quantity -= 1;
        }
        renderCart();
      });

      const quantity = document.createElement("span");
      quantity.textContent = item.quantity.toString();

      const increase = document.createElement("button");
      increase.type = "button";
      increase.textContent = "+";
      increase.setAttribute("aria-label", `Sumar ${item.name}`);
      increase.addEventListener("click", () => {
        item.quantity += 1;
        renderCart();
      });

      controls.append(decrease, quantity, increase);
      row.append(copy, controls);
      cartList?.append(row);
    });
  };

  const addCartItem = (button: HTMLButtonElement) => {
    const id = button.dataset.id ?? button.dataset.name ?? "producto";
    const name = button.dataset.name ?? "Producto";
    const price = Number(button.dataset.price ?? 0);
    const cycle = button.dataset.cycle ?? "Pago único";
    const current = cart.get(id);

    if (current) {
      current.quantity += 1;
    } else {
      cart.set(id, { id, name, price, cycle, quantity: 1 });
    }

    if (checkoutStatus) checkoutStatus.textContent = `${name} añadido al carrito.`;
    renderCart();
  };

  const escapeHtml = (value: string) =>
    value
      .replaceAll("&", "&amp;")
      .replaceAll("<", "&lt;")
      .replaceAll(">", "&gt;")
      .replaceAll('"', "&quot;")
      .replaceAll("'", "&#039;");

  const getFormValue = (formData: FormData, key: string) => formData.get(key)?.toString().trim() || "";

  const getSelectedOptionText = (form: HTMLFormElement, key: string, fallback: string) => {
    const field = form.elements.namedItem(key);
    if (field instanceof HTMLSelectElement) {
      return field.selectedOptions[0]?.textContent?.trim() || fallback;
    }

    return fallback;
  };

  const openOrderSummaryTab = (
    orderId: string,
    formData: FormData,
    products: CartItem[],
    total: number,
    checkoutFormElement: HTMLFormElement,
  ) => {
    const receiptWindow = window.open("", "_blank");
    if (!receiptWindow) return false;

    const name = getFormValue(formData, "name");
    const email = getFormValue(formData, "email");
    const phone = getFormValue(formData, "phone");
    const address = getFormValue(formData, "address");
    const postal = getFormValue(formData, "postal");
    const province = getSelectedOptionText(checkoutFormElement, "province", getFormValue(formData, "province"));
    const shipping = getSelectedOptionText(checkoutFormElement, "shipping", getFormValue(formData, "shipping"));
    const payment = getSelectedOptionText(checkoutFormElement, "payment", getFormValue(formData, "payment"));
    const notes = getFormValue(formData, "notes") || "Sin notas";
    const date = new Date().toLocaleString("es-ES", { dateStyle: "medium", timeStyle: "short" });

    const productRows = products
      .map(
        (item) => `
          <tr>
            <td>
              <strong>${escapeHtml(item.name)}</strong>
              <span>${escapeHtml(item.cycle)}</span>
            </td>
            <td>${item.quantity}</td>
            <td>${moneyFormatter.format(item.price)}</td>
            <td>${moneyFormatter.format(item.price * item.quantity)}</td>
          </tr>
        `,
      )
      .join("");

    receiptWindow.document.write(`
      <!doctype html>
      <html lang="es">
        <head>
          <meta charset="UTF-8" />
          <meta name="viewport" content="width=device-width, initial-scale=1.0" />
          <title>Pedido ${escapeHtml(orderId)} | WineNotFound</title>
          <style>
            :root { color-scheme: light; font-family: Inter, "Segoe UI", Arial, sans-serif; color: #171514; background: #f6f1e8; }
            body { margin: 0; background: linear-gradient(135deg, #fff7ea, #f0d6a3 36%, #cfd9ba 68%, #ead2dc); }
            main { box-sizing: border-box; width: min(980px, calc(100% - 32px)); margin: 0 auto; padding: 42px 0; }
            section { background: #fffaf2; border: 1px solid rgb(23 21 20 / 0.14); border-radius: 8px; padding: 26px; box-shadow: 0 18px 45px rgb(24 13 15 / 0.12); }
            h1, h2 { margin: 0; font-family: Georgia, "Times New Roman", serif; line-height: 1; }
            h1 { font-size: clamp(2.2rem, 6vw, 4.2rem); }
            h2 { font-size: 1.8rem; margin-top: 30px; }
            p { color: rgb(23 21 20 / 0.72); }
            .meta { display: flex; flex-wrap: wrap; gap: 10px; margin: 18px 0 0; }
            .meta span { background: rgb(195 154 82 / 0.24); color: #2b1018; border-radius: 999px; padding: 8px 12px; font-weight: 800; }
            dl { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 1px; background: rgb(23 21 20 / 0.14); border: 1px solid rgb(23 21 20 / 0.14); }
            div { min-width: 0; }
            dl div { background: #fffdf8; padding: 14px; }
            dt { color: rgb(23 21 20 / 0.58); font-size: 0.76rem; font-weight: 900; text-transform: uppercase; }
            dd { margin: 4px 0 0; font-weight: 700; overflow-wrap: anywhere; }
            table { width: 100%; margin-top: 14px; border-collapse: collapse; background: #fffdf8; }
            th, td { border-bottom: 1px solid rgb(23 21 20 / 0.14); padding: 14px; text-align: left; vertical-align: top; }
            th { color: rgb(23 21 20 / 0.58); font-size: 0.78rem; text-transform: uppercase; }
            td span { display: block; color: rgb(23 21 20 / 0.58); font-size: 0.88rem; margin-top: 3px; }
            .total { display: flex; justify-content: flex-end; gap: 18px; margin-top: 18px; font-size: 1.4rem; font-weight: 900; }
            .actions { margin-top: 26px; display: flex; gap: 10px; flex-wrap: wrap; }
            button { min-height: 44px; border: 0; border-radius: 999px; background: #641c2f; color: #fffaf2; padding: 10px 18px; font-weight: 900; cursor: pointer; }
            @media print { body { background: white; } main { width: 100%; padding: 0; } section { box-shadow: none; border: 0; } .actions { display: none; } }
            @media (max-width: 700px) { dl { grid-template-columns: 1fr; } th:nth-child(3), td:nth-child(3) { display: none; } }
          </style>
        </head>
        <body>
          <main>
            <section>
              <h1>Resumen de compra</h1>
              <div class="meta">
                <span>${escapeHtml(orderId)}</span>
                <span>${escapeHtml(date)}</span>
              </div>

              <h2>Cliente</h2>
              <dl>
                <div><dt>Nombre</dt><dd>${escapeHtml(name)}</dd></div>
                <div><dt>Email</dt><dd>${escapeHtml(email)}</dd></div>
                <div><dt>Teléfono</dt><dd>${escapeHtml(phone)}</dd></div>
                <div><dt>Dirección</dt><dd>${escapeHtml(address)}</dd></div>
                <div><dt>Código postal</dt><dd>${escapeHtml(postal)}</dd></div>
                <div><dt>Provincia</dt><dd>${escapeHtml(province)}</dd></div>
                <div><dt>Envío</dt><dd>${escapeHtml(shipping)}</dd></div>
                <div><dt>Pago</dt><dd>${escapeHtml(payment)}</dd></div>
                <div><dt>Notas</dt><dd>${escapeHtml(notes)}</dd></div>
              </dl>

              <h2>Productos comprados</h2>
              <table>
                <thead>
                  <tr>
                    <th>Producto</th>
                    <th>Cantidad</th>
                    <th>Precio</th>
                    <th>Subtotal</th>
                  </tr>
                </thead>
                <tbody>${productRows}</tbody>
              </table>
              <div class="total"><span>Total</span><strong>${moneyFormatter.format(total)}</strong></div>

              <div class="actions">
                <button type="button" onclick="window.print()">Imprimir</button>
                <button type="button" onclick="window.close()">Cerrar</button>
              </div>
            </section>
          </main>
        </body>
      </html>
    `);
    receiptWindow.document.close();
    receiptWindow.focus();
    return true;
  };

  cartAddButtons.forEach((button) => {
    button.addEventListener("click", () => {
      addCartItem(button);
      closeCheckoutPage();
      openCartDropdown();
    });
  });

  cartBuyButtons.forEach((button) => {
    button.addEventListener("click", () => {
      addCartItem(button);
      goToCheckoutPage();
    });
  });

  cartToggle?.addEventListener("click", () => {
    if (cartDropdown?.hidden) {
      openCartDropdown();
    } else {
      closeCartDropdown();
    }
  });

  cartClose?.addEventListener("click", closeCartDropdown);

  cartClear?.addEventListener("click", () => {
    cart.clear();
    if (checkoutStatus) checkoutStatus.textContent = "Carrito vaciado.";
    closeCheckoutPage();
    renderCart();
  });

  cartCheckout?.addEventListener("click", goToCheckoutPage);
  checkoutBack?.addEventListener("click", closeCheckoutPage);

  checkoutForm?.addEventListener("submit", (event) => {
    event.preventDefault();
    const { items, count, total } = getCartTotals();

    if (!items.length) {
      if (checkoutStatus) checkoutStatus.textContent = "Añade algún producto antes de pagar.";
      return;
    }

    const purchasedItems = items.map((item) => ({ ...item }));
    const formData = new FormData(checkoutForm);
    const rawName = formData.get("name");
    const name = rawName?.toString().trim().split(" ")[0] || "Cliente";
    const orderId = `WNF-${Date.now().toString().slice(-6)}`;
    const didOpenSummary = openOrderSummaryTab(orderId, formData, purchasedItems, total, checkoutForm);

    if (checkoutStatus) {
      checkoutStatus.textContent = didOpenSummary
        ? `${name}, compra ${orderId} completada: ${count} producto(s) por ${moneyFormatter.format(total)}. Se ha abierto el resumen en una nueva pestaña.`
        : `${name}, compra ${orderId} completada: ${count} producto(s) por ${moneyFormatter.format(total)}. El navegador ha bloqueado la pestaña del resumen.`;
    }

    cart.clear();
    checkoutForm.reset();
    renderCart();
  });

  renderCart();
</script>
